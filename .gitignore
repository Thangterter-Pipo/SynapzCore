# AGT_Brain — .gitignore

# Build artifacts
/target/
/target_build/
scripts/chatgpt_register/target/
# Cargo.lock ĐƯỢC commit (workspace có binary → build tái lập được)

# IDE & Editor
.vscode/
.idea/

# AI Agent internals
.claude/
.gitnexus/
.agentMemory/

# Secrets — NEVER commit
/data/
/memory/
.env
.env.local
*.env
!.env.example
# Runtime config chứa token/secret (token bot, key...) — KHÔNG commit
scripts/telegram_bridge.json
*_config.json
*.secret.json

# OS junk
Thumbs.db
.DS_Store

# Legacy
node_modules/
.venv_memory/
devops/
__pycache__/
*.pyc

# Binary
agt-mcp.exe
agt-mcp

# Scratch
scratch/

# Logs & runtime junk
*.log
HERMES.md
img_probe.py
scripts/.attachments/

# Portable Toolchain
mingw/
.toolchain/

# Screenshots & Images
*.png
*.jpg
*.jpeg
*.gif
*.webp


*.bak
*.bak-*

# Scripts upload cache
scripts/.upload_cache/

# IDE / tool-local (not part of the open-source project)
.kiro/
.codegraph/
