# SynapzCore — Environment variables (preferred over data/supabase_config.json)
#
# Copy this file to `.env` and fill in real values, OR export these in your shell.
# When SUPABASE_URL and SUPABASE_KEY are both set, the code uses them and
# ignores data/supabase_config.json entirely — keeping secrets out of files.
#
# Both the Rust layer (synapz-memory) and the Python layer (synapz_memory.py,
# graph_memory.py, dream_compression.py) read these.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key-here

# 9Router (local LLM proxy) — used by synapz_memory.py, graph_memory.py, dream_compression.py
NINEROUTER_URL=http://127.0.0.1:20128
NINEROUTER_KEY=sk-your-9router-key-here
# NINEROUTER_MODEL=ag/gemini-3-flash

# Dashboard server auth token — protects the SynapzCore HTTP API (port 8899)
# exposed via the public cloudflared tunnel. Requests without this token in
# header `X-Synapz-Token` (or ?token= query) are rejected with 401.
# Leave empty to DISABLE auth (NOT recommended when the tunnel is public).
SYNAPZ_API_TOKEN=change-me-to-a-long-random-string

# Optional: override repo root (defaults to E:\AGT_Brain)
# SYNAPZ_ROOT=E:\AGT_Brain

# Orchestrator roster — override the built-in demo agents without touching code.
# Format: comma-separated id:model:role triples (roles: Coder/Tester/Researcher/Builder).
# Example: SYNAPZ_AGENTS=dev:gpt-4o:Coder,qa:gpt-4o-mini:Tester
# SYNAPZ_AGENTS=
